{
  "kind": "collectionType",
  "collectionName": "bookings",
  "info": {
    "singularName": "booking",
    "pluralName": "bookings",
    "displayName": "Booking"
  },
  "attributes": {
    "user_email": {
      "type": "email",
      "required": true
    },
    "user_name": {
      "type": "string"
    },
    "seat_numbers": {
      "type": "json"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "confirmed",
        "cancelled"
      ],
      "default": "confirmed"
    },
    "qr_code": {
      "type": "string"
    },
    "showtime": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::showtime.showtime",
      "inversedBy": "bookings"
    }
  }
}