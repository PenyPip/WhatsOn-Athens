{
  "kind": "collectionType",
  "collectionName": "bookings",
  "info": {
    "singularName": "booking",
    "pluralName": "bookings",
    "displayName": "Booking",
    "description": "Ticket bookings"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "user_name": {
      "type": "string",
      "required": true
    },
    "user_email": {
      "type": "email",
      "required": true
    },
    "seat_numbers": {
      "type": "json"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "confirmed", "cancelled"],
      "default": "pending"
    },
    "qr_code": {
      "type": "string"
    },
    "showtime": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::showtime.showtime",
      "inversedBy": "bookings"
    }
  }
}
