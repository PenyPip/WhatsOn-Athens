{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "meta_description": {
      "type": "string"
    },
    "focus_keyword": {
      "type": "string"
    },
    "secondary_keywords": {
      "type": "string"
    },
    "content": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "articleSimple"
      }
    },
    "article_type": {
      "type": "enumeration",
      "enum": [
        "kritiki_parastasis",
        "kritiki_tainias",
        "sigkrisi",
        "giati_na_deis",
        "politistiko_keimeno"
      ]
    },
    "featured_image_alt": {
      "type": "string"
    },
    "featured_image": {
      "type": "media",
      "allowedTypes": [
        "images"
      ]
    },
    "related_movie": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::movie.movie",
      "inversedBy": "articles",
      "description": "Προαιρετικό — σύνδεση με ταινία. Επίλεξε είτε ταινία είτε παράσταση (όχι και τα δύο)."
    },
    "related_theater_show": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::theater-show.theater-show",
      "inversedBy": "articles",
      "description": "Προαιρετικό — σύνδεση με παράσταση θεάτρου. Επίλεξε είτε ταινία είτε παράσταση (όχι και τα δύο)."
    },
    "related_event": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::event.event",
      "inversedBy": "articles",
      "description": "Πολιτιστική εκδήλωση (Event) — εμφανίζεται πλήρως στο άρθρο. Ξεχωριστά από ταινία/παράσταση."
    },
    "tags": {
      "type": "component",
      "repeatable": true,
      "component": "shared.article-tag",
      "description": "Ετικέτες που εμφανίζονται κάτω από το κείμενο του άρθρου."
    }
  }
}
