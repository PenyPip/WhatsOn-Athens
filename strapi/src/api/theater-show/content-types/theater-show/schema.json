{
  "kind": "collectionType",
  "collectionName": "theater_shows",
  "info": {
    "singularName": "theater-show",
    "pluralName": "theater-shows",
    "displayName": "Theater Show"
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "synopsis": {
      "type": "text"
    },
    "director": {
      "type": "string"
    },
    "cast": {
      "type": "component",
      "repeatable": true,
      "component": "shared.cast-name",
      "description": "Λίστα συντελεστών: μία καταχώρηση ανά όνομα (χωρίς JSON)."
    },
    "genre": {
      "type": "enumeration",
      "enum": [
        "drama",
        "comedy",
        "musical",
        "dance",
        "opera"
      ]
    },
    "duration": {
      "type": "integer"
    },
    "run_start": {
      "type": "date",
      "description": "Πρώτη ημέρα εμφάνισης στο site (κενό = χωρίς όριο)."
    },
    "run_end": {
      "type": "date",
      "description": "Τελευταία ημέρα εμφάνισης (μετά δεν φαίνεται στη λίστα / αναζήτηση)."
    },
    "weekly_schedule": {
      "type": "component",
      "repeatable": true,
      "component": "theater.weekly-slot",
      "description": "Εβδομαδιαίες μέρες/ώρες."
    },
    "ticket_price_from": {
      "type": "decimal",
      "description": "Τιμή από (€)."
    },
    "ticket_price_to": {
      "type": "decimal",
      "description": "Τιμή έως (€). Ίδια με «από» = μία τιμή στο site."
    },
    "ticket_price": {
      "type": "decimal",
      "description": "(Παλιό) Μοναδική τιμή — προτιμήστε από/έως."
    },
    "poster": {
      "type": "media",
      "allowedTypes": [
        "images"
      ]
    },
    "is_premiere": {
      "type": "boolean",
      "default": false
    },
    "is_last_shows": {
      "type": "boolean",
      "default": false
    },
    "sold_out": {
      "type": "boolean",
      "default": false,
      "description": "Εμφάνιση ετικέτας SOLD OUT στις κάρτες παράστασης."
    },
    "on_tour": {
      "type": "boolean",
      "default": false,
      "description": "Περιοδεία — εμφανίζεται στο τμήμα tours της αρχικής. Δεν απαιτείται χώρος (venue)."
    },
    "more_link": {
      "type": "string",
      "description": "URL περιοδείας, κρατήσεων ή επίσημης σελίδας της παράστασης (όχι στον χώρο)."
    },
    "event_group_code": {
      "type": "string",
      "description": "More.com eventGroupCode (π.χ. evg_takouniastonbalto_1254_5019). Βρες με More lookup."
    },
    "more_event_groups": {
      "type": "component",
      "repeatable": true,
      "component": "cinema.more-event-group",
      "description": "Επιπλέον More κωδικοί για την ίδια παράσταση."
    },
    "pending_event_group_code": {
      "type": "string",
      "private": true,
      "description": "Προτεινόμενος More κωδικός — αναμένει έγκριση admin."
    },
    "pending_more_title": {
      "type": "string",
      "private": true,
      "description": "Τίτλος στο More για την προτεινόμενη ταύτιση."
    },
    "pending_match_score": {
      "type": "decimal",
      "private": true,
      "description": "Score ταύτισης CMS↔More (0–1)."
    },
    "venue": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::venue.venue",
      "inversedBy": "theater_shows",
      "description": "Προαιρετικό — σταθερή σκηνή. Κενό για περιοδείες χωρίς συγκεκριμένο venue."
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-review.user-review",
      "mappedBy": "theater_show"
    },
    "editorial_reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::editorial-review.editorial-review",
      "mappedBy": "theater_show"
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "related_theater_show"
    }
  }
}