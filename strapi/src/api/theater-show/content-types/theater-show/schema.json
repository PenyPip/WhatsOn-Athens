{
  "kind": "collectionType",
  "collectionName": "theater_shows",
  "info": {
    "singularName": "theater-show",
    "pluralName": "theater-shows",
    "displayName": "Theater Show"
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "synopsis": {
      "type": "text"
    },
    "director": {
      "type": "string"
    },
    "cast": {
      "type": "json"
    },
    "genre": {
      "type": "enumeration",
      "enum": [
        "drama",
        "comedy",
        "musical",
        "dance",
        "opera"
      ]
    },
    "duration": {
      "type": "integer"
    },
    "poster": {
      "type": "media",
      "allowedTypes": [
        "images"
      ]
    },
    "tags": {
      "type": "json"
    },
    "gradient_from": {
      "type": "string"
    },
    "gradient_to": {
      "type": "string"
    },
    "is_premiere": {
      "type": "boolean",
      "default": false
    },
    "is_last_shows": {
      "type": "boolean",
      "default": false
    },
    "venue": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::venue.venue",
      "inversedBy": "theater_shows"
    },
    "showtimes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::showtime.showtime",
      "mappedBy": "theater_show"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-review.user-review",
      "mappedBy": "theater_show"
    },
    "editorial_reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::editorial-review.editorial-review",
      "mappedBy": "theater_show"
    }
  }
}