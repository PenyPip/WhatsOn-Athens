{
  "kind": "collectionType",
  "collectionName": "venues",
  "info": {
    "singularName": "venue",
    "pluralName": "venues",
    "displayName": "Χώρος / Σινεμά",
    "description": "Π.χ. Village The Mall, θερινό Αθήνα κ.λπ. Τύπος: Σινεμά / Θέατρο κ.λπ. Το πεδίο «Θερινό» ξεχωρίζει τα θερινά σινεμά από τα κλειστά."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "address": {
      "type": "string"
    },
    "city": {
      "type": "enumeration",
      "enum": ["athens", "thessaloniki", "other"]
    },
    "district": {
      "type": "enumeration",
      "enum": ["center", "north", "south", "west", "east", "piraeus", "greater_other"],
      "description": "Υποπεριοχή (κυρίως για Αθήνα)· για φίλτρο «Περιοχή» στη σελίδα Ταινιών."
    },
    "google_maps_url": {
      "type": "string"
    },
    "more_link": {
      "type": "string",
      "description": "URL ιστοσελίδας/κρατήσεων· εμφανίζεται ως «Περισσότερα» στη λίστα χώρων."
    },
    "seats_total": {
      "type": "integer"
    },
    "image": {
      "type": "media",
      "allowedTypes": ["images"]
    },
    "halls": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::hall.hall",
      "mappedBy": "venue"
    },
    "type": {
      "type": "string"
    },
    "summer_outdoor": {
      "type": "boolean",
      "default": false
    },
    "theater_shows": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::theater-show.theater-show",
      "mappedBy": "venue"
    },
    "showtimes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::showtime.showtime",
      "mappedBy": "venue"
    }
  }
}