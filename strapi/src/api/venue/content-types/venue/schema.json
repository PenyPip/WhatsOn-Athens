{
  "kind": "collectionType",
  "collectionName": "venues",
  "info": {
    "singularName": "venue",
    "pluralName": "venues",
    "displayName": "Venue",
    "description": "Cinemas and theater venues"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "address": {
      "type": "string"
    },
    "city": {
      "type": "enumeration",
      "enum": ["athens", "thessaloniki", "other"],
      "default": "athens"
    },
    "google_maps_url": {
      "type": "string"
    },
    "seats_total": {
      "type": "integer"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "theater_shows": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::theater-show.theater-show",
      "mappedBy": "venue"
    },
    "showtimes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::showtime.showtime",
      "mappedBy": "venue"
    }
  }
}
