{
  "kind": "collectionType",
  "collectionName": "movies",
  "info": {
    "singularName": "movie",
    "pluralName": "movies",
    "displayName": "Ταινία",
    "description": "Δημιούργησε πρώτα την ταινία. Οι μέρες και οι ώρες ανά σινεμά προστίθενται με εγγραφές «Προβολή ταινίας»: κάθε μία = ένα Venue + ημερομηνία/ώρα."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "greek_title": {
      "type": "string",
      "description": "Ελληνικός τίτλος· εμφανίζεται ως κύρια γραμμή όταν συμπληρωθεί μαζί με τον πρωτότυπο."
    },
    "original_title": {
      "type": "string",
      "description": "Πρωτότυπος τίτλος (π.χ. διεθνής)· δεύτερη γραμμή στην κάρτα/λήμμα όταν υπάρχει και ελληνικός."
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "synopsis": {
      "type": "text"
    },
    "director": {
      "type": "string"
    },
    "cast": {
      "type": "json"
    },
    "movie_genre": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::movie-genre.movie-genre",
      "description": "Είδος ταινίας· διαχείριση από τη συλλογή «Είδος ταινίας»."
    },
    "duration": {
      "type": "integer"
    },
    "language": {
      "type": "string"
    },
    "age_rating": {
      "type": "string"
    },
    "poster": {
      "type": "media",
      "allowedTypes": ["images"]
    },
    "trailer_url": {
      "type": "string"
    },
    "release_date": {
      "type": "date"
    },
    "critic_score": {
      "type": "decimal"
    },
    "showtimes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::showtime.showtime",
      "mappedBy": "movie"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-review.user-review",
      "mappedBy": "movie"
    },
    "editorial_reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::editorial-review.editorial-review",
      "mappedBy": "movie"
    }
  }
}
