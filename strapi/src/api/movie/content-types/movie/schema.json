{
  "kind": "collectionType",
  "collectionName": "movies",
  "info": {
    "singularName": "movie",
    "pluralName": "movies",
    "displayName": "Movie"
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "synopsis": {
      "type": "text"
    },
    "director": {
      "type": "string"
    },
    "cast": {
      "type": "json"
    },
    "genre": {
      "type": "enumeration",
      "enum": [
        "action",
        "drama",
        "comedy",
        "thriller",
        "horror",
        "documentary",
        "sci-fi",
        "romance"
      ]
    },
    "duration": {
      "type": "integer"
    },
    "language": {
      "type": "string"
    },
    "age_rating": {
      "type": "string"
    },
    "poster": {
      "type": "media",
      "allowedTypes": [
        "images"
      ]
    },
    "trailer_url": {
      "type": "string"
    },
    "release_date": {
      "type": "date"
    },
    "critic_score": {
      "type": "decimal"
    },
    "gradient_from": {
      "type": "string"
    },
    "gradient_to": {
      "type": "string"
    },
    "showtimes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::showtime.showtime",
      "mappedBy": "movie"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-review.user-review",
      "mappedBy": "movie"
    },
    "editorial_reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::editorial-review.editorial-review",
      "mappedBy": "movie"
    }
  }
}