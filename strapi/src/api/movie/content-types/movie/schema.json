{
  "kind": "collectionType",
  "collectionName": "movies",
  "info": {
    "singularName": "movie",
    "pluralName": "movies",
    "displayName": "Ταινία",
    "description": "Δημιούργησε πρώτα την ταινία. Οι μέρες και οι ώρες ανά σινεμά προστίθενται με εγγραφές «Προβολή ταινίας»: κάθε μία = ένα Venue + ημερομηνία/ώρα."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "synopsis": {
      "type": "text"
    },
    "director": {
      "type": "string"
    },
    "cast": {
      "type": "json"
    },
    "genre": {
      "type": "enumeration",
      "enum": [
        "action",
        "adventure",
        "animation",
        "comedy",
        "documentary",
        "drama",
        "fantasy",
        "horror",
        "musical",
        "romance",
        "sci-fi",
        "thriller",
        "other"
      ],
      "description": "Είδος ταινίας (ως επιλογή από λίστα — και το site το δείχνει σαν «Είδος»)."
    },
    "duration": {
      "type": "integer"
    },
    "is_new": {
      "type": "boolean",
      "default": false,
      "description": "Τσεκάρισέ το για «Νέες ταινίες» στην αρχική."
    },
    "language": {
      "type": "string"
    },
    "age_rating": {
      "type": "string"
    },
    "poster": {
      "type": "media",
      "allowedTypes": ["images"]
    },
    "poster_url": {
      "type": "string"
    },
    "trailer_url": {
      "type": "string"
    },
    "release_date": {
      "type": "date"
    },
    "critic_score": {
      "type": "decimal"
    },
    "showtimes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::showtime.showtime",
      "mappedBy": "movie"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-review.user-review",
      "mappedBy": "movie"
    },
    "editorial_reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::editorial-review.editorial-review",
      "mappedBy": "movie"
    }
  }
}
