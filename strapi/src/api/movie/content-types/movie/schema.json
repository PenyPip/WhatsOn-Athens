{
  "kind": "collectionType",
  "collectionName": "movies",
  "info": {
    "singularName": "movie",
    "pluralName": "movies",
    "displayName": "Movie",
    "description": "Movies showing in cinemas"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "synopsis": {
      "type": "text"
    },
    "director": {
      "type": "string"
    },
    "cast": {
      "type": "json"
    },
    "genre": {
      "type": "enumeration",
      "enum": ["action", "drama", "comedy", "thriller", "horror", "documentary", "romance", "sci-fi", "animation", "other"],
      "default": "other"
    },
    "duration": {
      "type": "integer"
    },
    "language": {
      "type": "string"
    },
    "age_rating": {
      "type": "string"
    },
    "poster": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "trailer_url": {
      "type": "string"
    },
    "release_date": {
      "type": "date"
    },
    "critic_score": {
      "type": "decimal"
    },
    "gradient_from": {
      "type": "string",
      "default": "#1a1a2e"
    },
    "gradient_to": {
      "type": "string",
      "default": "#e94560"
    },
    "showtimes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::showtime.showtime",
      "mappedBy": "movie"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "movie"
    }
  }
}
