{
  "kind": "collectionType",
  "collectionName": "showtimes",
  "info": {
    "singularName": "showtime",
    "pluralName": "showtimes",
    "displayName": "Προβολή ταινίας",
    "description": "Μία προβολή = ένα σινεμά (Venue) + ημερομηνία και ώρα. Για άλλη μέρα ή άλλο σινεμά, πρόσθεσε νέα εγγραφή ή μέσα από την ταινία → Προβολές."
  },
  "attributes": {
    "datetime": {
      "type": "datetime",
      "required": true
    },
    "available_seats": {
      "type": "integer"
    },
    "price": {
      "type": "decimal"
    },
    "movie": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::movie.movie",
      "inversedBy": "showtimes"
    },
    "theater_show": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::theater-show.theater-show",
      "inversedBy": "showtimes"
    },
    "venue": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::venue.venue",
      "inversedBy": "showtimes"
    }
  }
}