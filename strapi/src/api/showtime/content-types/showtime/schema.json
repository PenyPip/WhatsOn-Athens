{
  "kind": "collectionType",
  "collectionName": "showtimes",
  "info": {
    "singularName": "showtime",
    "pluralName": "showtimes",
    "displayName": "Showtime"
  },
  "attributes": {
    "show_slots": {
      "type": "component",
      "repeatable": true,
      "component": "showtime.show-slot"
    },
    "available_seats": {
      "type": "integer"
    },
    "price": {
