{
  "kind": "collectionType",
  "collectionName": "restaurants",
  "info": {
    "singularName": "restaurant",
    "pluralName": "restaurants",
    "displayName": "Restaurant"
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "synopsis": {
      "type": "text"
    },
    "cuisine": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::cuisine.cuisine",
      "inversedBy": "restaurants"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::restaurant-category.restaurant-category",
      "inversedBy": "restaurants"
    },
    "neighborhood": {
      "type": "string"
    },
    "city": {
      "type": "enumeration",
      "enum": [
        "athens",
        "thessaloniki",
        "other"
      ]
    },
    "district": {
      "type": "enumeration",
      "enum": ["center", "north", "south", "west", "east", "piraeus", "greater_other"],
      "description": "Υποπεριοχή (κυρίως για Αθήνα) — ίδιες τιμές με τους χώρους σινεμά."
    },
    "price_range": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "google_maps_url": {
      "type": "string",
      "description": "Σύνδεσμος Google Maps (share/embed) — προτιμάται έναντι αυτόματης αναζήτησης από διεύθυνση."
    },
    "phone": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "instagram": {
      "type": "string"
    },
    "opening_date": {
      "type": "date"
    },
    "is_new": {
      "type": "boolean",
      "default": true
    },
    "poster": {
      "type": "media",
      "allowedTypes": [
        "images"
      ]
    },
    "editorial_score": {
      "type": "decimal"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-review.user-review",
      "mappedBy": "restaurant"
    },
    "editorial_reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::editorial-review.editorial-review",
      "mappedBy": "restaurant"
    }
  }
}