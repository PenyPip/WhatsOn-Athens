HOST=0.0.0.0
PORT=1337

# Docker dev: τα παρακάτω επικαλύπτονται από τα environment του docker-compose.dev.yml αν ορίσεις τις ίδιες τιμές.
DATABASE_CLIENT=mysql2
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_NAME=whatson
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi_pass

APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# PUBLIC_URL: URL που «βλέπει» ο browser (admin, redirects).
# Docker dev: στο docker-compose.dev.yml ορίζεται http://localhost:3000 (μέσω Next proxy).
# Μόνο Strapi :1337 χωρίς proxy: PUBLIC_URL=http://localhost:1337

# More showtime sync — worker mode (default) τρέχει σε ξεχωριστή διεργασία.
# MORE_SHOWTIME_SYNC_IN_PROCESS=true  # μόνο dev — τρέχει μέσα στο Strapi (ρίσκο 502/OOM)
# MORE_SHOWTIME_SYNC_PREFETCH=true    # ταχύτερο αλλά πολύ μνήμη — OFF by default
# MORE_SHOWTIME_SYNC_CONCURRENCY=5
# MORE_SHOWTIME_SYNC_DELAY_MS=40
# MORE_SHOWTIME_SYNC_EVENTS_CACHE_MAX=512
# MORE_SHOWTIME_SYNC_WORKER_HEAP=768
# MORE_SHOWTIME_SYNC_START_DELAY_MS=2500
